{
  "name": "nextjs-llms-plugin",
  "version": "0.1.0",
  "description": "Generate llms.txt and llms-full.txt for Next.js apps during build.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "check": "npm run typecheck && npm test && npm run build",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke:next": "node scripts/smoke-next-build.mjs",
    "format": "prettier --write ."
  },
  "keywords": [
    "nextjs",
    "llms.txt",
    "llms-full.txt",
    "webpack",
    "plugin"
  ],
  "license": "MIT",
  "peerDependencies": {
    "next": ">=13"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prettier": "^3.3.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
